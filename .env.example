# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-real-secret

# Database
DATABASE_URL=sqlite:///quest_dev.db

# AWS / Bedrock
# NOTE: NEVER store AWS credentials here. Use AWS CLI profiles, IAM roles,
# or environment variables set outside this file (e.g. via `aws configure`
# or instance/container roles).
AWS_REGION=eu-west-1
BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-20250514-v1:0

# Gunicorn (production)
GUNICORN_BIND=0.0.0.0:8000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
